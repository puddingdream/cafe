          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus?category=LATTE",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menus"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "LATTE"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Menus",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menus",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menus"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02 Points",
