# Cafe Order System local environment example.
#
# Usage:
# 1. Copy this file to .env
# 2. Fill JWT_SECRET_KEY
# 3. Run docker compose up -d
# 4. Run ./gradlew.bat bootRun
#
# Do not commit .env.

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Base64 encoded secret key.
# It must decode to at least 32 bytes for HS256.
#
# Example generation:
#   openssl rand -base64 32
JWT_SECRET_KEY=

# Access token TTL in milliseconds.
# 3600000 = 1 hour
JWT_ACCESS_TOKEN_VALIDITY_TIME=3600000

# Refresh token TTL in milliseconds.
# 1209600000 = 14 days
JWT_REFRESH_TOKEN_VALIDITY_TIME=1209600000

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------
# docker-compose.yml exposes MySQL as localhost:33306.
DB_HOST=localhost
DB_PORT=33306
DB_NAME=cafe
DB_USERNAME=root
DB_PASSWORD=12345678

# Local development uses update for convenience.
# For production, validate or a migration tool such as Flyway/Liquibase is safer.
JPA_DDL_AUTO=update

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Used for cache, popular menu ZSET, and Redisson distributed lock.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
# docker-compose.yml exposes Kafka external listener as localhost:9094.
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_CONSUMER_GROUP_ID=cafe-service

# -----------------------------------------------------------------------------
# Spring AI / OpenAI
# -----------------------------------------------------------------------------
# none:
#   AI recommendation endpoint returns a clear not-configured error.
# openai:
#   Enables Spring AI OpenAI chat model. OPENAI_API_KEY is required.
SPRING_AI_MODEL_CHAT=none
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.4

# -----------------------------------------------------------------------------
# Object storage for menu images
# -----------------------------------------------------------------------------
# false:
#   App can boot without S3 settings.
#   Menu image upload fails clearly with MENU_IMAGE_STORAGE_DISABLED.
#
# true:
#   MEDIA_STORAGE_BUCKET and credentials/provider settings are required.
MEDIA_STORAGE_ENABLED=false
MEDIA_STORAGE_BUCKET=
MEDIA_STORAGE_REGION=ap-northeast-2

# Optional S3-compatible endpoint.
# Empty value means AWS S3 default endpoint.
# Example for local/minio:
#   MEDIA_STORAGE_ENDPOINT=http://localhost:9000
MEDIA_STORAGE_ENDPOINT=

# Optional CDN or public base URL.
# Empty value builds AWS S3 style URL.
MEDIA_STORAGE_PUBLIC_BASE_URL=

# Optional static credentials.
# If empty, AWS DefaultCredentialsProvider is used.
MEDIA_STORAGE_ACCESS_KEY=
MEDIA_STORAGE_SECRET_KEY=

# true is usually needed for MinIO or some S3-compatible storage.
MEDIA_STORAGE_PATH_STYLE_ACCESS=false
MEDIA_STORAGE_KEY_PREFIX=menu-images
MEDIA_STORAGE_MAX_IMAGE_SIZE_BYTES=10485760

# -----------------------------------------------------------------------------
# Dummy data
# -----------------------------------------------------------------------------
# true:
#   Seeds local admin/user accounts and sample menus.
# false:
#   No startup seed data.
DUMMY_DATA_ENABLED=true
